{
  "author": "Dennis Gerike",
  "dependencies": {
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "currency-codes": "2.2.0",
    "express": "5.2.1",
    "i18n-iso-countries": "7.14.0",
    "inflection": "3.0.2",
    "iso-639-1": "3.1.5",
    "neo4j-driver": "6.0.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "description": "REST API for the open car database 'More Cars'",
  "devDependencies": {
    "@cucumber/cucumber": "12.9.0",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.4.0",
    "@inquirer/prompts": "8.5.2",
    "@redocly/cli": "2.31.5",
    "@seriousme/openapi-schema-validator": "2.9.0",
    "@types/k6": "2.0.0",
    "@types/supertest": "7.2.0",
    "@usebruno/cli": "3.4.2",
    "@vitest/coverage-v8": "4.1.7",
    "ajv": "8.20.0",
    "change-case": "5.4.4",
    "dotenv": "17.4.2",
    "eslint": "10.4.1",
    "hygen": "6.2.11",
    "inquirer": "14.0.2",
    "inquirer-file-selector": "1.0.1",
    "moment": "2.30.1",
    "supertest": "7.2.2",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=26"
  },
  "license": "MIT",
  "name": "@more-cars/rest-api",
  "repository": "https://github.com/more-cars/rest-api",
  "scripts": {
    "start": "NODE_ENV=production npx ts-node src/server.ts",
    "local:app:start": "./deployment/local-app-start.sh",
    "local:db:start": "./deployment/local-db-start.sh",
    "local:hostnames:add": "./deployment/add-local-hostnames.sh",
    "app:deploy": "./deployment/deploy-app.sh",
    "app:undeploy": "./deployment/undeploy-app.sh",
    "db:restore": "./deployment/restore-database.sh",
    "minikube:install": "deployment/minikube-install.sh",
    "minikube:start": "deployment/minikube-cluster-start.sh",
    "minikube:stop": "deployment/minikube-cluster-stop.sh",
    "minikube:delete": "deployment/minikube-cluster-delete.sh",
    "generate-code": "node --env-file=.env -r ts-node/register code_generator/generate-code-for-feature.ts",
    "generate-code:image-relationships": "node --env-file=.env -r ts-node/register code_generator/generate-code-for-images.ts",
    "generate-code:video-relationships": "node --env-file=.env -r ts-node/register code_generator/generate-code-for-videos.ts",
    "tests:validate-api-schema": "npx ts-node tests/api-validation/schema-validation.ts",
    "tests:lint:src": "npx eslint src",
    "tests:lint:tests": "npx eslint tests",
    "tests:unit": "npx vitest run -c tests/unit/vite.config.ts",
    "tests:integration": "npx vitest run -c tests/integration/vite.config.ts",
    "tests:developer": "./tests/developer/run-tests.sh",
    "tests:smoke:gui": "npm run start --workspace=@more-cars/rest-api-mock-servers & bruno",
    "tests:smoke:cli": "./tests/smoke/run-smoke-tests.sh",
    "tests:behavior": "node --env-file=.env -r ts-node/register tests/behavior/check-dependencies.ts true && npm run start --workspace=@more-cars/rest-api-mock-servers & npx cucumber-js --tags '@implemented and not @deactivated'",
    "tests:behavior:single": "node --env-file=.env -r ts-node/register tests/behavior/run-single-test.ts",
    "tests:performance": "./tests/performance/run-tests.sh"
  },
  "workspaces": [
    "mock-servers",
    "statistics"
  ],
  "version": "0.37.0"
}
